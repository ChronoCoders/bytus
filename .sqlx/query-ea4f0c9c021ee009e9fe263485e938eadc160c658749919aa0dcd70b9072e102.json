  "query": "SELECT\n               b.id,\n               b.hash,\n               b.prev_hash,\n               b.created_at,\n               (SELECT COUNT(*) FROM chain_events WHERE block_id = b.id) AS event_count\n           FROM blocks b\n           ORDER BY b.id DESC\n           LIMIT 50",
